{
  "plugins": [],
  "categories": {
    "correctness": "off",
    "suspicious": "off",
    "pedantic": "off",
    "perf": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "jsPlugins": ["../src/index.ts"],
  "rules": {
    "crescware-prefer-satisfies-over-annotation/prefer-satisfies-over-annotation": [
      "error",
      {
        "allowEmptyLiteral": {
          "message": "Empty literal: 'satisfies' cannot type it; declare the type with an explicit annotation instead."
        }
      }
    ]
  }
}
